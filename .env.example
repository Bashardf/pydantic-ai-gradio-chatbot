# --- AI Models ---
# OpenAI API Key (required for OpenAI models and RAG embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Model to use. Examples:
# - openai:gpt-4o-mini (recommended default)
# - ollama:llama3 (for local LLM via Ollama)
# - test (for mock responses without API/Ollama)
MODEL_NAME=openai:gpt-4o-mini

# Ollama specific
OLLAMA_BASE_URL=http://localhost:11434/v1

# RAG Settings
EMBEDDING_MODEL=text-embedding-3-small

# --- Application Settings ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Gradio Settings (Demo/Admin UI)
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false

# --- Security & Limits ---
MAX_UPLOAD_SIZE_MB=20
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PDF_REQUESTS=5

# --- Prompts ---
# Optional: Override the default system prompt
# SYSTEM_PROMPT="You are a helpful assistant..."
