# Kopiere nach .env und trage echte Werte ein – .env NIEMALS committen!
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=openai:gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Gradio / Deployment
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false

# Chatverlauf (data/history/<SESSION_ID>.json)
CHAT_SESSION_ID=default

# Rate Limits (pro App-Instanz)
RATE_LIMIT_CHAT_REQUESTS=30
RATE_LIMIT_CHAT_WINDOW=60
RATE_LIMIT_PDF_REQUESTS=5
RATE_LIMIT_PDF_WINDOW=3600
